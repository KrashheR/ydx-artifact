{
  "name": "anomaly-archive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:validate": "tsx scripts/dev-validate.ts",
    "dev:validate:cheat": "tsx scripts/dev-validate.ts --cheat",
    "validate:final": "tsx scripts/dev-validate.ts --final --cheat",
    "preview": "vite preview --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:content": "tsx scripts/validate-content.ts",
    "agent:check": "pnpm lint && pnpm typecheck && pnpm validate:content",
    "agent:release-check": "pnpm validate:content && pnpm build && pnpm test:e2e",
    "release:validate": "pnpm validate:content && pnpm build",
    "release:manifest": "tsx scripts/release-manifest.ts",
    "release:zip": "tsx scripts/release-zip.ts",
    "release:checksum": "tsx scripts/release-checksum.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "i18next": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-legacy": "^6.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
