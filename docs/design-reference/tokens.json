      "artifactReveal":      "card flips in from below, 500ms; glow ochre ring 600ms",
      "mapRouteProgress":    "line draws along path, 400ms easingOut per segment",
      "rewardedLoading":     "archive-paper spinner rotation, 1.2s linear loop",
      "cloudSaveStatus":     "toast slides up 200ms, holds 2s, slides down 200ms",
      "modalEnter":          "opacity 0→1 + translateY 16px→0, 200ms easingOut",
      "modalExit":           "opacity 1→0 + translateY 0→8px, 150ms easingIn"
    }
  },
  "breakpoints": {
