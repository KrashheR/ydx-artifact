  "typography": {
    "families": {
      "display":  "Playfair Display, Georgia, serif",
      "mono":     "IBM Plex Mono, Menlo, monospace",
      "ui":       "Inter, system-ui, sans-serif"
    },
    "scale": {
      "xs":   { "size": "12px", "lineHeight": "1.4", "usage": "Decorative archive codes, tiny labels" },
      "sm":   { "size": "14px", "lineHeight": "1.4", "usage": "Captions, secondary metadata" },
      "base": { "size": "16px", "lineHeight": "1.5", "usage": "Body text, descriptions (mobile minimum)" },
      "md":   { "size": "18px", "lineHeight": "1.5", "usage": "Important UI text, card titles" },
      "lg":   { "size": "22px", "lineHeight": "1.3", "usage": "Section headers, modal titles" },
      "xl":   { "size": "28px", "lineHeight": "1.2", "usage": "Chapter titles, major headings" },
      "2xl":  { "size": "36px", "lineHeight": "1.1", "usage": "Game title, splash" },
      "3xl":  { "size": "48px", "lineHeight": "1.0", "usage": "Hero display text" }
    },
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "rules": [
      "Playfair Display: titles and chapter headings only; never body or small text",
      "IBM Plex Mono: archive numbers, dates, coordinates, accession codes",
      "Inter: all functional UI — buttons, navigation, descriptions, HUD, settings",
      "Mobile body minimum: 16px",
      "Archive codes may be 12px when decorative only",
      "Do not overuse uppercase; use sentence case for most UI strings"
    ]
  },
  "spacing": {
    "1":  "4px",
