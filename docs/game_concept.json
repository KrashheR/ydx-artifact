  "productIdentity": {
    "oneSentencePitchRu": "Игрок восстанавливает парные снимки исчезнувшей северной экспедиции, находит аномальные расхождения и собирает музейный архив найденных предметов.",
    "oneSentencePitchEn": "The player restores paired photographs from a vanished northern expedition, finds anomalous differences, and builds a small museum archive of recovered artifacts.",
    "playerFantasy": "Я внимательный архивист и исследователь, который замечает скрытые несоответствия, восстанавливает ход экспедиции и раскрывает спокойную тайну.",
    "marketHook": "Понятная за несколько секунд механика «найди отличия» объединена с картой маршрута, коллекционными экспонатами, daily-ритмом и аккуратным сюжетным контекстом.",
    "emotionalTone": [
      "уютная тайна",
      "исследование",
      "северная экспедиция",
      "архивная достоверность",
      "спокойная сосредоточенность"
    ],
    "notTone": [
      "хоррор",
      "детская мультяшность",
      "казино",
      "неоновый sci-fi",
      "грязный постапокалипсис",
      "агрессивный free-to-play"
    ]
  },
  "audience": {
    "primaryAge": "25-60",
    "coreMotivations": [
      "расслабиться и сосредоточиться",
      "получать короткие завершённые победы",
      "собирать коллекцию",
      "открывать новые сцены",
      "возвращаться к ежедневному испытанию"
    ],
    "accessibilityPriority": "high",
    "readingPriority": "high",
    "mobileOneHandPriority": "high"
  },
  "designPillars": [
    {
      "id": "instant_comprehension",
      "name": "Механика понятна за 3 секунды",
      "rules": [
        "На ключевых промо- и игровых экранах сразу видны две версии одной сцены или понятный режим A/B.",
        "Первое реальное игровое действие происходит не позднее 20 секунд после запуска.",
        "Обязательная регистрация до начала игры запрещена."
      ]
    },
    {
      "id": "comfort_over_punishment",
      "name": "Комфорт важнее наказания",
      "rules": [
        "В кампании нет энергии, жизней и окончательного проигрыша.",
        "Основная кампания не использует жёсткий таймер.",
        "Ошибка снижает точность, но не отнимает валюту и не сбрасывает уровень."
      ]
    },
    {
      "id": "tactile_discovery",
      "name": "Каждое найденное отличие приятно ощущается",
      "rules": [
        "Правильное нажатие подтверждается формой, анимацией, звуком и необязательной вибрацией.",
        "Найденное отличие синхронно отмечается на обеих версиях изображения.",
        "Маркеры не перекрывают важные детали сцены."
      ]
    },
    {
      "id": "mobile_native",
      "name": "Mobile — самостоятельный UX",
      "rules": [
        "На portrait mobile используется полноэкранное переключение A/B, а не две микроскопические картинки.",
        "Камера и масштаб синхронизированы между версиями.",
        "Все важные действия доступны одним пальцем."
      ]
    },
    {
      "id": "light_meta",
      "name": "Мета остаётся лёгкой",
      "rules": [
        "Мета состоит из карты, четырёх экспонатов, daily и streak.",
        "Нет строительства, merge, нескольких валют, energy-system и battle pass.",
        "Мета усиливает желание пройти следующую сцену, но не заменяет основную игру."
      ]
    },
    {
      "id": "trustworthy_progress",
      "name": "Прогресс вызывает доверие",
      "rules": [
        "Состояние сохраняется после каждого найденного отличия.",
        "SDK, реклама или облако не должны создавать тупиковые состояния.",
        "При конфликте сохранений не теряются завершённые уровни, экспонаты и покупки."
      ]
    }
  ],
