  "coreLoop": {
    "sessionLoop": [
      "open-game",
      "see-daily-and-active-progress",
      "enter-level",
      "find-differences",
      "receive-seals-and-reward",
      "advance-map",
      "occasionally-unlock-artifact",
      "return-next-day"
    ],
    "levelLoop": [
      "show-short-level-card",
      "load-paired-scene",
      "search-and-mark-differences",
      "optionally-use-hint",
      "complete-scene",
      "calculate-seals",
      "show-reward",
      "return-to-map"
    ],
    "targetDurationsSeconds": {
      "tutorialLevel": "60-90",
      "standardLevel": "120-180",
      "hardLevel": "180-300",
      "returningSession": "180-480",
      "firstSession": "1200-2100"
    }
  },
  "gameplayRules": {
    "campaignTimer": false,
    "energy": false,
    "lives": false,
    "permanentFailState": false,
    "differenceTypes": [
      "missing-object",
      "color-change",
      "shape-change",
      "quantity-change",
      "moved-object",
      "symbol-or-instrument-change",
      "reflection-or-shadow-change",
      "subtle-surreal-anomaly"
    ],
    "forbiddenDifferenceTypes": [
      "single-pixel-change",
      "compression-artifact",
      "ambiguous-texture-noise",
      "unmarked-random-ai-difference",
      "difference-requiring-color-only-identification"
    ],
    "misclick": {
      "reducesAccuracy": true,
      "removesCurrency": false,
      "resetsLevel": false,
      "rapidMisclickThreshold": 3,
      "temporaryInputLockMs": 700,
      "panGestureMustNotCount": true
    },
    "seals": [
      {
        "id": "completed",
        "titleRu": "Восстановлено",
        "condition": "level_completed"
      },
      {
        "id": "accurate-eye",
        "titleRu": "Точный глаз",
        "condition": "accuracy_gte_0_85"
      },
      {
        "id": "no-intervention",
        "titleRu": "Без вмешательства",
        "condition": "exact_hint_not_used"
      }
    ]
  },
  "hints": {
    "areaHint": {
      "id": "area_hint",
      "titleRu": "Ориентир",
      "effect": "temporarily_highlight_hint_area",
      "costMagnifiers": 1
